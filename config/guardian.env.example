# GuardianD secrets — environment file
#
# Copy to /etc/guardian/guardian.env, fill in the values you use, and lock it down:
#   sudo install -m 600 -o root -g root config/guardian.env.example /etc/guardian/guardian.env
#   sudo nano /etc/guardian/guardian.env
#
# The shipped systemd unit already loads this file (EnvironmentFile=-/etc/guardian/guardian.env),
# so these become environment variables for the daemon. Environment values OVERRIDE the
# matching fields in guardian.yaml — so you can keep secrets out of the config file entirely
# (leave those fields blank/"" in guardian.yaml).
#
# Format: KEY=value  — one per line, no quotes, no spaces around '='. Lines starting with # are ignored.

# --- Alert channels ---
# GUARDIAN_SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/YYY/ZZZ
# GUARDIAN_TELEGRAM_TOKEN=1234567890:AA...
# GUARDIAN_TELEGRAM_CHAT_ID=-1001234567890
# GUARDIAN_EMAIL_PASSWORD=your-smtp-app-password

# --- REST API ---
# GUARDIAN_API_TOKEN=some-long-random-bearer-token

# --- AI-assisted alerts (OpenAI / OpenAI-compatible) ---
# GUARDIAN_OPENAI_API_KEY takes precedence; OPENAI_API_KEY is accepted as a fallback.
# GUARDIAN_OPENAI_API_KEY=sk-...

# --- Identity (optional) ---
# GUARDIAN_INSTANCE_NAME=prod-api-01
# GUARDIAN_ENVIRONMENT=production
# AWS account labels (shown on every alert). Account ID auto-detects from EC2
# IMDS when blank and is displayed redacted (starting****ending); the account
# name is not exposed by IMDS, so set it here if you want a human label.
# GUARDIAN_AWS_ACCOUNT_ID=123456789012
# GUARDIAN_AWS_ACCOUNT_NAME=AlgoRec
